#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${ROOT}" ]]; then
  exit 0
fi
cd "${ROOT}"

unstaged_changes="$(git diff --name-status --)"
untracked_files="$(git ls-files --others --exclude-standard)"
if [[ -n "${unstaged_changes}" || -n "${untracked_files}" ]]; then
  echo "[pre-commit] Unstaged files are not allowed. Stage or stash them before committing."
  if [[ -n "${unstaged_changes}" ]]; then
    echo "[pre-commit] Tracked unstaged changes:"
    printf '%s\n' "${unstaged_changes}"
  fi
  if [[ -n "${untracked_files}" ]]; then
    echo "[pre-commit] Untracked files:"
    while IFS= read -r path; do
      printf '??\t%s\n' "${path}"
    done <<< "${untracked_files}"
  fi
  exit 1
fi

tmp_before_fmt="$(mktemp)"
tmp_after_fmt="$(mktemp)"
tmp_fmt_log="$(mktemp)"
tmp_clippy_log="$(mktemp)"
tmp_deny_log="$(mktemp)"
tmp_baseline_log="/tmp/unsafe-baseline-hook.log"
tmp_error_audit_log="/tmp/public-error-audit-hook.log"
cleanup() {
  rm -f "${tmp_before_fmt}" "${tmp_after_fmt}" "${tmp_fmt_log}" "${tmp_clippy_log}" "${tmp_deny_log}"
}
trap cleanup EXIT

git diff >"${tmp_before_fmt}"
echo "[pre-commit] Running cargo fmt"
if ! cargo fmt >"${tmp_fmt_log}" 2>&1; then
  echo "[pre-commit] cargo fmt failed."
  cat "${tmp_fmt_log}"
  exit 1
fi
git diff >"${tmp_after_fmt}"
if ! cmp -s "${tmp_before_fmt}" "${tmp_after_fmt}"; then
  echo "[pre-commit] cargo fmt produced changes. Stage formatted files and commit again."
  git diff --name-only
  exit 1
fi

echo "[pre-commit] Running cargo clippy --workspace --all-targets -- -D warnings"
if ! cargo clippy --workspace --all-targets -- -D warnings >"${tmp_clippy_log}" 2>&1; then
  echo "[pre-commit] cargo clippy failed."
  cat "${tmp_clippy_log}"
  exit 1
fi

echo "[pre-commit] Running cargo deny check"
if ! cargo deny check --disable-fetch >"${tmp_deny_log}" 2>&1; then
  echo "[pre-commit] cargo deny check failed."
  cat "${tmp_deny_log}"
  exit 1
fi

baseline_mismatch=0
echo "[public-error-audit] Refreshing docs/public-error-audit.csv"
if ! cargo +nightly -Zscript tools/error_audit.rs --write docs/public-error-audit.csv >"${tmp_error_audit_log}" 2>&1; then
  echo "[public-error-audit] Failed to run audit script."
  cat "${tmp_error_audit_log}"
  exit 1
fi

if ! git diff --quiet -- docs/public-error-audit.csv; then
  echo "[public-error-audit] Audit changed. Stage it and commit again:"
  echo "  git add docs/public-error-audit.csv"
  git diff -- docs/public-error-audit.csv
  baseline_mismatch=1
fi

staged="$(git diff --cached --name-only --diff-filter=ACMR)"
needs_baseline=0
while IFS= read -r path; do
  [[ -z "${path}" ]] && continue
  case "${path}" in
    doradb-storage/src/buffer/*|\
    doradb-storage/src/latch/*|\
    doradb-storage/src/row/*|\
    doradb-storage/src/index/*|\
    doradb-storage/src/io/*|\
    doradb-storage/src/trx/*|\
    doradb-storage/src/lwc/*|\
    doradb-storage/src/file/*|\
    doradb-storage/src/log/*|\
    tools/unsafe_inventory.rs|\
    docs/unsafe-usage-baseline.md)
      needs_baseline=1
      break
      ;;
  esac
done <<< "${staged}"

if [[ "${SKIP_UNSAFE_BASELINE_HOOK:-0}" != "1" && "${needs_baseline}" -eq 1 ]]; then
  echo "[unsafe-baseline] Refreshing docs/unsafe-usage-baseline.md"
  if ! cargo +nightly -Zscript tools/unsafe_inventory.rs --write docs/unsafe-usage-baseline.md >"${tmp_baseline_log}" 2>&1; then
    echo "[unsafe-baseline] Failed to run inventory script."
    cat "${tmp_baseline_log}"
    exit 1
  fi

  if ! git diff --quiet -- docs/unsafe-usage-baseline.md; then
    echo "[unsafe-baseline] Baseline changed. Stage it and commit again:"
    echo "  git add docs/unsafe-usage-baseline.md"
    git diff -- docs/unsafe-usage-baseline.md
    baseline_mismatch=1
  fi
fi

exit "${baseline_mismatch}"
